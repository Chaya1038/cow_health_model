<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HerdHealth"
        tools:targetApi="31">

        <!-- Veterinary Doctor Dashboard Activity -->
        <activity
            android:name=".VetDashboardActivity"
            android:exported="false" />

        <!-- Veterinary Cow Details Activity -->
        <activity
            android:name=".VetCowDetailsActivity"
            android:exported="false" />

        <!-- Splash Screen (Launcher Activity) -->
        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Activity -->
        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <!-- Signup Activity -->
        <activity
            android:name=".SignupActivity"
            android:exported="false" />

        <!-- User Selection (Farmer or Vet) -->
        <activity
            android:name=".UserSelectionActivity"
            android:exported="false" />

        <!-- Cow List (Farmer's Home Screen) -->
        <activity
            android:name=".CowListActivity"
            android:exported="false" />

        <!-- Cow Details Page -->
        <activity
            android:name=".CowDetailsActivity"
            android:exported="false"
            android:parentActivityName=".CowListActivity" />

    </application>

</manifest>
